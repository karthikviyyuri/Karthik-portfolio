---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Tag from "../../components/ui/Tag.astro";
import { profile } from "../../data/portfolio";

export const prerender = true;

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project }
  }));
}

interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
const { Content } = await project.render();
const allProjects = (await getCollection("projects")).sort((a, b) => a.data.title.localeCompare(b.data.title));
const currentIndex = allProjects.findIndex((item) => item.slug === project.slug);
const nextProject = allProjects[(currentIndex + 1) % allProjects.length];
---

<BaseLayout title={`${project.data.title} - ${profile.name}`} description={project.data.summary}>
  <header class="section-shell page-header work-header">
    <p class="section-kicker">{project.data.category}</p>
    <h1 class="section-title">{project.data.title}</h1>
    <p class="section-copy">{project.data.summary}</p>
    <div class="tag-list">
      {project.data.technologies.map((tech) => <Tag label={tech} />)}
    </div>
  </header>

  <section class="section-shell section-shell--tight work-metrics" aria-label="Key metrics">
    {project.data.metrics.map((metric) => (
      <div class="panel work-metric">
        <strong>{metric.value}</strong>
        <span>{metric.label}</span>
      </div>
    ))}
  </section>

  <section class="section-shell section-shell--tight work-sections">
    {project.data.sections.map((section) => (
      <article>
        <span>{section.label}</span>
        <p>{section.body}</p>
      </article>
    ))}
  </section>

  <section class="section-shell section-shell--tight">
    <div class="prose-block work-content">
      <Content />
    </div>
    <nav class="work-nav" aria-label="Project navigation">
      <a class="button" href="/">Back home</a>
      {nextProject && <a class="button button--solid" href={`/work/${nextProject.slug}`}>Next: {nextProject.data.title}</a>}
    </nav>
  </section>
</BaseLayout>

<style>
  .work-header .tag-list {
    margin-top: 1.5rem;
  }

  .work-metrics {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .work-metric {
    display: grid;
    gap: 0.35rem;
    min-height: 8rem;
    padding: 1rem;
  }

  .work-metric strong {
    color: var(--accent-primary);
    font-family: var(--font-mono);
    font-size: 1.6rem;
  }

  .work-metric span {
    color: var(--text-secondary);
  }

  .work-sections {
    display: grid;
    gap: 1rem;
  }

  .work-sections article {
    border-top: 1px solid var(--border-subtle);
    display: grid;
    gap: 1rem;
    grid-template-columns: 9rem minmax(0, 1fr);
    padding-top: 1.2rem;
  }

  .work-sections span {
    color: var(--accent-primary);
    font-family: var(--font-mono);
    font-size: 0.76rem;
    text-transform: uppercase;
  }

  .work-sections p {
    color: var(--text-secondary);
    margin: 0;
  }

  .work-content {
    max-width: 760px;
  }

  .work-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  @media (max-width: 820px) {
    .work-metrics,
    .work-sections article {
      grid-template-columns: 1fr;
    }
  }
</style>
