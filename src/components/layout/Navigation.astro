---
import { DownloadIcon, MenuIcon, XIcon } from "lucide-react";
import { profile } from "../../data/portfolio";

const navLinks = [
  { href: "/about", label: "About" },
  { href: "/experience", label: "Experience" },
  { href: "/impact", label: "Impact" },
  { href: "/work/cache-augmented-multimodal-sentiment", label: "Work" },
  { href: "/recommendations", label: "Recommendations" },
  { href: "/stack", label: "Stack" },
  { href: "/articles", label: "Articles" },
  { href: "/contact", label: "Contact" }
];

const pathname = Astro.url.pathname;
---

<header class="site-nav" id="site-nav" transition:persist>
  <a class="site-nav__brand" href="/" aria-label="Karthik Viyyuri home">KV</a>
  <nav class="site-nav__links" aria-label="Primary navigation">
    {navLinks.map((link) => (
      <a class:list={["site-nav__link", pathname === link.href || (link.href.startsWith("/work") && pathname.startsWith("/work")) ? "is-active" : ""]} href={link.href}>
        {link.label}
      </a>
    ))}
  </nav>
  <a class="site-nav__resume" href={profile.resumeHref} aria-label="Download resume">
    <DownloadIcon size={16} aria-hidden="true" />
    <span>Resume</span>
  </a>
  <button class="site-nav__menu" type="button" aria-expanded="false" aria-controls="mobile-nav" aria-label="Open navigation">
    <MenuIcon className="site-nav__menu-open" size={20} aria-hidden="true" />
    <XIcon className="site-nav__menu-close" size={20} aria-hidden="true" />
  </button>
  <div class="mobile-nav" id="mobile-nav" aria-hidden="true">
    {navLinks.map((link) => (
      <a href={link.href}>{link.label}</a>
    ))}
    <a href={profile.resumeHref}>Download Resume</a>
  </div>
</header>

<script>
  function bootNavigation(): void {
    const nav = document.getElementById("site-nav");
    const brand = nav?.querySelector(".site-nav__brand");
    const button = nav?.querySelector(".site-nav__menu");
    const mobileNav = document.getElementById("mobile-nav");
    if (!(button instanceof HTMLButtonElement) || !mobileNav) {
      return;
    }

    const menuButton = button;
    const mobilePanel = mobileNav;

    function isActiveHref(href: string): boolean {
      const currentPath = window.location.pathname;
      const linkPath = new URL(href, window.location.origin).pathname;
      return currentPath === linkPath || (linkPath.startsWith("/work") && currentPath.startsWith("/work"));
    }

    function updateActiveLinks(): void {
      nav?.querySelectorAll<HTMLAnchorElement>(".site-nav__link, .mobile-nav a").forEach((link) => {
        const active = isActiveHref(link.href);
        link.classList.toggle("is-active", active);
        if (active) {
          link.setAttribute("aria-current", "page");
        } else {
          link.removeAttribute("aria-current");
        }
      });
    }

    if (menuButton.dataset.booted === "true") {
      updateActiveLinks();
      return;
    }
    menuButton.dataset.booted = "true";

    function closeMenu(): void {
      menuButton.setAttribute("aria-expanded", "false");
      menuButton.setAttribute("aria-label", "Open navigation");
      mobilePanel.setAttribute("aria-hidden", "true");
      nav?.classList.remove("is-open");
    }

    function toggleMenu(): void {
      const next = menuButton.getAttribute("aria-expanded") !== "true";
      menuButton.setAttribute("aria-expanded", String(next));
      menuButton.setAttribute("aria-label", next ? "Close navigation" : "Open navigation");
      mobilePanel.setAttribute("aria-hidden", String(!next));
      nav?.classList.toggle("is-open", next);
    }

    menuButton.addEventListener("click", toggleMenu);
    mobilePanel.querySelectorAll("a").forEach((link) => link.addEventListener("click", closeMenu));
    brand?.addEventListener("click", () => {
      window.sessionStorage.setItem("portfolioIntroSeen", "true");
      document.body.classList.remove("intro-active");
      document.documentElement.classList.add("intro-complete");
    });

    const onScroll = () => {
      nav?.classList.toggle("is-scrolled", window.scrollY > 12);
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();
    updateActiveLinks();
  }

  document.addEventListener("astro:page-load", bootNavigation);
  bootNavigation();
</script>

<style>
  .site-nav {
    align-items: center;
    display: grid;
    gap: 1rem;
    grid-template-columns: auto 1fr auto auto;
    left: 50%;
    max-width: 1180px;
    padding: 0.8rem 1rem;
    position: fixed;
    top: 2.6rem;
    transform: translateX(-50%);
    transition: background-color 180ms ease, border-color 180ms ease;
    width: min(calc(100% - 2rem), 1180px);
    z-index: 70;
  }

  .site-nav.is-scrolled,
  .site-nav.is-open {
    background: rgba(10, 10, 10, 0.82);
    border: 1px solid var(--border-subtle);
    border-radius: 8px;
    backdrop-filter: blur(18px);
  }

  .site-nav__brand {
    align-items: center;
    background: rgba(10, 10, 10, 0.45);
    border: 1px solid var(--border-default);
    border-radius: 50%;
    color: var(--text-accent);
    display: inline-flex;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    height: 2.3rem;
    justify-content: center;
    position: relative;
    transition: background-color 180ms ease, border-color 180ms ease, box-shadow 180ms ease, color 180ms ease, transform 180ms ease;
    width: 2.3rem;
  }

  .site-nav__brand:hover,
  .site-nav__brand:focus-visible {
    background: rgba(212, 168, 83, 0.12);
    border-color: rgba(212, 168, 83, 0.72);
    box-shadow:
      0 0 0 1px rgba(212, 168, 83, 0.12),
      0 0 18px rgba(212, 168, 83, 0.34),
      0 0 42px rgba(212, 168, 83, 0.16),
      inset 0 0 18px rgba(212, 168, 83, 0.1);
    color: #f4dfb6;
    outline: none;
    transform: translateY(-1px);
  }

  .site-nav__links {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    justify-content: center;
  }

  .site-nav__link {
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    position: relative;
    transition: color 160ms ease;
  }

  .site-nav__link::after {
    background: var(--accent-primary);
    bottom: -0.35rem;
    content: "";
    height: 1px;
    left: 0;
    position: absolute;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 160ms ease;
    width: 100%;
  }

  .site-nav__link:hover,
  .site-nav__link:focus-visible,
  .site-nav__link.is-active {
    color: var(--text-primary);
  }

  .site-nav__link.is-active::after,
  .site-nav__link:hover::after,
  .site-nav__link:focus-visible::after {
    transform: scaleX(1);
  }

  .site-nav__resume {
    align-items: center;
    background: rgba(10, 10, 10, 0.35);
    border: 1px solid var(--border-default);
    border-radius: 999px;
    color: var(--text-primary);
    display: inline-flex;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    gap: 0.4rem;
    min-height: 2.25rem;
    padding: 0 0.8rem;
    transition: background-color 180ms ease, border-color 180ms ease, box-shadow 180ms ease, color 180ms ease, transform 180ms ease;
  }

  .site-nav__resume:hover,
  .site-nav__resume:focus-visible {
    background: rgba(212, 168, 83, 0.13);
    border-color: rgba(212, 168, 83, 0.68);
    box-shadow:
      0 0 0 1px rgba(212, 168, 83, 0.1),
      0 0 20px rgba(212, 168, 83, 0.3),
      0 0 54px rgba(212, 168, 83, 0.14),
      inset 0 0 18px rgba(212, 168, 83, 0.08);
    color: var(--text-accent);
    outline: none;
    transform: translateY(-1px);
  }

  .site-nav__menu {
    align-items: center;
    background: transparent;
    border: 1px solid var(--border-default);
    border-radius: 50%;
    color: var(--text-primary);
    display: none;
    height: 2.35rem;
    justify-content: center;
    width: 2.35rem;
  }

  .site-nav__menu-close,
  .site-nav.is-open .site-nav__menu-open {
    display: none;
  }

  .site-nav.is-open .site-nav__menu-close {
    display: block;
  }

  .mobile-nav {
    display: none;
  }

  @media (max-width: 980px) {
    .site-nav {
      grid-template-columns: auto 1fr auto;
      top: 2.3rem;
    }

    .site-nav.is-open {
      align-content: start;
      grid-template-rows: auto 1fr;
      height: calc(100vh - 1rem);
      left: 0.5rem;
      top: 0.5rem;
      transform: none;
      width: calc(100% - 1rem);
    }

    .site-nav__links,
    .site-nav__resume {
      display: none;
    }

    .site-nav__menu {
      display: inline-flex;
      grid-column: 3;
    }

    .mobile-nav {
      border-top: 1px solid var(--border-subtle);
      display: none;
      grid-column: 1 / -1;
      padding: 1rem 0 0.35rem;
    }

    .site-nav.is-open .mobile-nav {
      display: grid;
      align-content: start;
      gap: 0.85rem;
    }

    .mobile-nav a {
      color: var(--text-secondary);
      font-family: var(--font-mono);
      font-size: 1.1rem;
      padding: 0.25rem 0;
    }

    .mobile-nav a.is-active,
    .mobile-nav a[aria-current="page"] {
      color: var(--text-accent);
    }
  }

  @media (max-width: 520px) {
    .site-nav {
      width: min(calc(100% - 1rem), 1180px);
    }
  }
</style>
