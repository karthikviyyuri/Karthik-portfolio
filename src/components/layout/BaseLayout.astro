---
import { ViewTransitions } from "astro:transitions";
import AlienRagdollFall from "../effects/AlienRagdollFall.astro";
import IntroLoader from "../intro/IntroLoader.astro";
import ParticleCanvas from "../canvas/ParticleCanvas.astro";
import HUD from "../hud/HUD.astro";
import Footer from "./Footer.astro";
import Navigation from "./Navigation.astro";
import TechCursor from "../ui/TechCursor.astro";
import UfoScrollPath from "../scroll/UfoScrollPath.astro";
import "../../styles/global.css";
import "../../styles/alien-abduction.css";
import "../../styles/alien-ragdoll.css";
import "../../styles/intro.css";
import "../../styles/ufo-path.css";
import { profile } from "../../data/portfolio";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${profile.name} - AI/ML Engineer`,
  description = profile.shortBio
} = Astro.props;

const showIntro = Astro.url.pathname === "/";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0a" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/og-image.jpg" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="canonical" href={Astro.url.href} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <script is:inline>document.documentElement.classList.add("js");</script>
    <title>{title}</title>
    <ViewTransitions />
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    {showIntro && <IntroLoader />}
    <ParticleCanvas />
    <AlienRagdollFall />
    <UfoScrollPath />
    <HUD />
    <TechCursor />
    <Navigation />
    <main class="site-main" id="content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
