---
import type { CollectionEntry } from "astro:content";
import Tag from "./Tag.astro";

interface Props {
  project: CollectionEntry<"projects">;
  compact?: boolean;
}

const { project, compact = false } = Astro.props;
const data = project.data;
---

<a class:list={["project-card", compact ? "project-card--compact" : ""]} href={`/work/${project.slug}`}>
  <div class="project-card__top">
    <span class="project-card__category">{data.category}</span>
    <span class="project-card__time">{data.timeframe}</span>
  </div>
  <h3>{data.title}</h3>
  <p>{data.summary}</p>
  <div class="project-card__hover">
    {data.sections.slice(0, compact ? 2 : 3).map((section) => (
      <div>
        <strong>{section.label}</strong>
        <span>{section.body}</span>
      </div>
    ))}
  </div>
  <div class="project-card__metrics">
    {data.metrics.slice(0, 3).map((metric) => (
      <span>{metric.value} <small>{metric.label}</small></span>
    ))}
  </div>
  <div class="tag-list">
    {data.technologies.slice(0, compact ? 3 : 5).map((tech) => <Tag label={tech} />)}
  </div>
</a>

<style>
  .project-card {
    background: rgba(22, 22, 22, 0.76);
    border: 1px solid var(--border-default);
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    min-height: 25rem;
    overflow: hidden;
    padding: 1.25rem;
    position: relative;
    transition: border-color 200ms ease, transform 200ms ease, background-color 200ms ease;
  }

  .project-card:hover,
  .project-card:focus-visible {
    background: rgba(26, 26, 26, 0.9);
    border-color: rgba(212, 168, 83, 0.48);
    transform: translateY(-4px);
  }

  .project-card--compact {
    min-height: 20rem;
  }

  .project-card__top {
    align-items: center;
    color: var(--text-muted);
    display: flex;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    gap: 0.75rem;
    justify-content: space-between;
  }

  .project-card__category {
    color: var(--accent-primary);
  }

  .project-card h3 {
    color: var(--text-primary);
    font-size: 1.45rem;
    line-height: 1.12;
    margin: 0;
  }

  .project-card p {
    color: var(--text-secondary);
    margin: 0;
  }

  .project-card__hover {
    display: grid;
    gap: 0.75rem;
    margin-top: auto;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 200ms ease, transform 200ms ease;
  }

  .project-card:hover .project-card__hover,
  .project-card:focus-visible .project-card__hover {
    opacity: 1;
    transform: translateY(0);
  }

  .project-card__hover div {
    display: grid;
    gap: 0.15rem;
  }

  .project-card__hover strong {
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: 0.73rem;
  }

  .project-card__hover span {
    color: var(--text-muted);
    font-size: 0.82rem;
    line-height: 1.45;
  }

  .project-card__metrics {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .project-card__metrics span {
    color: var(--accent-primary);
    font-family: var(--font-mono);
    font-size: 0.92rem;
  }

  .project-card__metrics small {
    color: var(--text-muted);
    font-size: 0.68rem;
  }

  @media (hover: none) {
    .project-card__hover {
      opacity: 1;
      transform: none;
    }
  }
</style>

