---
interface Props {
  value: string;
  label: string;
  context?: string;
  href?: string;
}

const { value, label, context, href } = Astro.props;
const Element = href ? "a" : "div";
---

<Element class="metric-card" href={href}>
  <span class="metric-card__value">{value}</span>
  <span class="metric-card__label">{label}</span>
  {context && <span class="metric-card__context">{context}</span>}
</Element>

<style>
  .metric-card {
    background: rgba(22, 22, 22, 0.72);
    border: 1px solid var(--border-default);
    border-radius: 8px;
    display: grid;
    gap: 0.45rem;
    min-height: 9rem;
    padding: 1rem;
    transition: border-color 180ms ease, transform 180ms ease;
  }

  .metric-card:hover,
  .metric-card:focus-visible {
    border-color: rgba(212, 168, 83, 0.48);
    transform: translateY(-2px);
  }

  .metric-card__value {
    color: var(--accent-primary);
    font-family: var(--font-mono);
    font-size: 1.75rem;
    line-height: 1;
  }

  .metric-card__label {
    color: var(--text-primary);
    font-weight: 600;
    line-height: 1.3;
  }

  .metric-card__context {
    color: var(--text-muted);
    font-size: 0.82rem;
    line-height: 1.45;
  }
</style>

