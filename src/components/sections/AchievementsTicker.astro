---
import { getEntry } from "astro:content";
import RevealOnScroll from "../ui/RevealOnScroll.astro";

const achievements = await getEntry("achievements", "achievements");
const items = achievements?.data.items ?? [];
const rows = [items, [...items].reverse()];
---

<section class="ticker-section" data-ufo-section="achievements" aria-label="Achievements">
  <div class="ticker-section__rows">
    {rows.map((row, rowIndex) => (
      <RevealOnScroll variant={rowIndex === 1 ? "right" : "left"} delay={rowIndex * 100}>
        <a class:list={["ticker-row", rowIndex === 1 ? "ticker-row--reverse" : ""]} href="/about#achievements">
          <span class="ticker-row__track">
            {[...row, ...row].map((item) => (
              <span class="ticker-item">
                <span class="ticker-item__dot"></span>
                <strong>{item.metric ?? item.title}</strong>
                <span>{item.title}</span>
                <small>{item.date}</small>
              </span>
            ))}
          </span>
        </a>
      </RevealOnScroll>
    ))}
  </div>
</section>

<style>
  .ticker-section {
    border-block: 1px solid var(--border-subtle);
    overflow: hidden;
    padding: 1rem 0;
  }

  .ticker-section__rows {
    display: grid;
    gap: 0.75rem;
  }

  .ticker-row {
    color: var(--text-secondary);
    display: flex;
    overflow: hidden;
    white-space: nowrap;
  }

  .ticker-row__track {
    animation: ticker-left 36s linear infinite;
    display: inline-flex;
    min-width: max-content;
  }

  .ticker-row--reverse .ticker-row__track {
    animation-name: ticker-right;
  }

  .ticker-row:hover .ticker-row__track,
  .ticker-row:focus-visible .ticker-row__track {
    animation-play-state: paused;
  }

  .ticker-item {
    align-items: center;
    display: inline-flex;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    gap: 0.65rem;
    padding: 0 1.2rem;
  }

  .ticker-item__dot {
    background: var(--accent-primary);
    border-radius: 50%;
    height: 0.38rem;
    width: 0.38rem;
  }

  .ticker-item strong {
    color: var(--accent-primary);
    font-weight: 600;
  }

  .ticker-item small {
    color: var(--text-muted);
    font-size: 0.7rem;
  }
</style>
