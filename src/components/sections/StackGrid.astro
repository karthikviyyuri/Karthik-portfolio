---
import { getEntry } from "astro:content";
import RevealOnScroll from "../ui/RevealOnScroll.astro";

const stack = await getEntry("stack", "stack");
const categories = stack?.data.categories ?? [];
---

<section class="stack-grid" aria-label="Technology stack">
  {categories.map((category, index) => (
    <RevealOnScroll variant="up" delay={index * 90}>
      <article class="panel stack-grid__category">
        <div>
          <h3>{category.name}</h3>
          <p>{category.context}</p>
        </div>
        <div class="stack-grid__items">
          {category.items.map((item) => (
            <span class="stack-grid__item" tabindex="0">
              <span class="stack-grid__logo" aria-hidden="true">
                {item.logo && <img src={item.logo} alt="" loading="lazy" decoding="async" />}
              </span>
              <strong>{item.name}</strong>
              <em>{item.note}</em>
            </span>
          ))}
        </div>
      </article>
    </RevealOnScroll>
  ))}
</section>

<style>
  .stack-grid {
    display: grid;
    gap: 1rem;
  }

  .stack-grid__category {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: 17rem minmax(0, 1fr);
    padding: 1.1rem;
  }

  .stack-grid h3 {
    color: var(--text-primary);
    font-size: 1.05rem;
    margin: 0 0 0.5rem;
  }

  .stack-grid p {
    color: var(--text-muted);
    margin: 0;
  }

  .stack-grid__items {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem 1rem;
  }

  .stack-grid__item {
    align-items: center;
    color: var(--text-secondary);
    display: inline-grid;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    gap: 0.45rem;
    justify-items: center;
    min-width: 5rem;
    position: relative;
  }

  .stack-grid__logo {
    align-items: center;
    border: 1px solid var(--border-subtle);
    border-radius: 50%;
    display: inline-flex;
    height: 3.5rem;
    justify-content: center;
    transition: background-color 180ms ease, border-color 180ms ease, box-shadow 180ms ease, transform 180ms ease;
    width: 3.5rem;
  }

  .stack-grid__items img {
    flex: 0 0 auto;
    height: 1.35rem;
    object-fit: contain;
    width: 1.35rem;
  }

  .stack-grid__item strong {
    font-size: 0.7rem;
    line-height: 1.2;
    max-width: 6.6rem;
    text-align: center;
  }

  .stack-grid__item:hover,
  .stack-grid__item:focus-visible {
    color: var(--text-primary);
    outline: none;
  }

  .stack-grid__item:hover .stack-grid__logo,
  .stack-grid__item:focus-visible .stack-grid__logo {
    background: rgba(212, 168, 83, 0.08);
    border-color: rgba(212, 168, 83, 0.5);
    box-shadow:
      0 0 0 1px rgba(212, 168, 83, 0.08),
      0 0 22px rgba(212, 168, 83, 0.16),
      inset 0 0 16px rgba(212, 168, 83, 0.06);
    transform: translateY(-2px);
  }

  .stack-grid__items em {
    background: #0d0d0d;
    border: 1px solid var(--border-default);
    border-radius: 8px;
    bottom: calc(100% + 0.45rem);
    color: var(--text-secondary);
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-style: normal;
    left: 0;
    line-height: 1.35;
    opacity: 0;
    padding: 0.55rem 0.7rem;
    pointer-events: none;
    position: absolute;
    transform: translateY(4px);
    transition: opacity 160ms ease, transform 160ms ease;
    width: 16rem;
    z-index: 5;
  }

  .stack-grid__item:hover em,
  .stack-grid__item:focus-visible em {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 820px) {
    .stack-grid__category {
      grid-template-columns: 1fr;
    }
  }
</style>
