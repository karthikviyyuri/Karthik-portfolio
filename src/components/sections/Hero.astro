---
import { ArrowDownIcon, Code2Icon, DownloadIcon, MailIcon, NetworkIcon } from "lucide-react";
import { profile, socialLinks } from "../../data/portfolio";
import ConstellationAvatar from "../canvas/ConstellationAvatar.astro";
import ExternalLink from "../ui/ExternalLink.astro";

const nameLines = ["Karthik", "Viyyuri"];
---

<section class="hero" data-ufo-section="hero" aria-label="Introduction">
  <div class="hero__time mono" id="hero-clock">{profile.hudCity} / 00:00:00</div>
  <div class="hero__content">
    <p class="hero__eyebrow">{profile.headline}</p>
    <h1 class="hero__name" aria-label={profile.name} tabindex="0">
      {nameLines.map((line, lineIndex) => (
        <span class="hero__name-line" aria-hidden="true">
          {[...line].map((letter, letterIndex) => (
            <span class="hero__letter" style={`--letter-delay:${lineIndex * 80 + letterIndex * 38}ms`}>{letter}</span>
          ))}
        </span>
      ))}
    </h1>
    <div class="hero__role" role="status">
      <span>{profile.role}</span>
      <span>{profile.roleDetail}</span>
    </div>
    <div class="hero__actions">
      <a class="button button--solid" href={profile.resumeHref}>
        <DownloadIcon size={16} aria-hidden="true" />
        Download Resume
      </a>
      <a class="button" href="/work/cache-augmented-multimodal-sentiment">View Research</a>
    </div>
    <nav class="hero__social" aria-label="Social links">
      {socialLinks.map((link) => (
        <ExternalLink class="hero__social-link" href={link.href} label={link.label}>
          {link.label === "GitHub" && <Code2Icon size={18} aria-hidden="true" />}
          {link.label === "LinkedIn" && <NetworkIcon size={18} aria-hidden="true" />}
          {link.label === "Email" && <MailIcon size={18} aria-hidden="true" />}
          <span>{link.label}</span>
        </ExternalLink>
      ))}
    </nav>
    <p class="hero__tag mono">Optimising: validation paths / Not: inflated claims</p>
  </div>
  <ConstellationAvatar />
  <a class="hero__scroll mono" href="#about">
    <span>Scroll</span>
    <ArrowDownIcon size={16} aria-hidden="true" />
  </a>
</section>

<script is:inline define:vars={{ city: profile.hudCity, timezone: profile.timezone }}>
  function bootHeroClock() {
    const clock = document.getElementById("hero-clock");
    if (!clock) return;

    function update() {
      const now = new Date().toLocaleTimeString("en-IN", {
        timeZone: timezone,
        hour12: false,
        hour: "2-digit",
        minute: "2-digit",
        second: "2-digit"
      });
      clock.textContent = `${city} / ${now}`;
    }

    update();
    window.clearInterval(window.__karthikHeroClock);
    window.__karthikHeroClock = window.setInterval(update, 1000);
  }

  document.addEventListener("astro:page-load", bootHeroClock);
  bootHeroClock();
</script>

<style>
  .hero {
    align-items: center;
    display: grid;
    gap: 2rem;
    grid-template-columns: minmax(0, 1fr) minmax(20rem, 34rem);
    min-height: 100vh;
    padding: 9rem max(1rem, calc((100vw - 1120px) / 2)) 5rem;
    position: relative;
  }

  .hero__time {
    color: var(--accent-primary);
    font-size: 0.78rem;
    left: max(1rem, calc((100vw - 1120px) / 2));
    position: absolute;
    top: 8rem;
  }

  .hero__content {
    display: grid;
    gap: 1.25rem;
    max-width: 760px;
  }

  .hero__eyebrow {
    color: var(--text-secondary);
    font-size: 1.05rem;
    margin: 0;
    max-width: 660px;
  }

  .hero__name {
    color: var(--text-accent);
    display: grid;
    font-size: 7rem;
    font-weight: 700;
    letter-spacing: 0;
    line-height: 0.9;
    margin: 0;
    position: relative;
    width: fit-content;
  }

  .hero__name-line {
    animation: line-in 720ms ease both;
    display: flex;
  }

  .hero__name-line:nth-child(2) {
    animation-delay: 150ms;
  }

  .hero__letter {
    color: var(--text-accent);
    display: inline-block;
    -webkit-text-stroke: 0 transparent;
    text-shadow: none;
    transition:
      color 260ms ease,
      filter 260ms ease,
      text-shadow 260ms ease,
      transform 260ms ease,
      -webkit-text-stroke-color 260ms ease;
    transition-delay: var(--letter-delay);
    will-change: color, filter, text-shadow, transform;
  }

  .hero__name::before {
    content: "";
    inset: -2.4rem -3rem;
    pointer-events: auto;
    position: absolute;
  }

  .hero__name:hover .hero__letter,
  .hero__name:focus-visible .hero__letter {
    color: var(--text-accent);
    filter: drop-shadow(0 0 10px rgba(212, 168, 83, 0.42));
    -webkit-text-stroke-color: rgba(244, 223, 182, 0.96);
    text-shadow:
      0 0 12px rgba(212, 168, 83, 0.42),
      0 0 34px rgba(212, 168, 83, 0.2),
      0 0 72px rgba(212, 168, 83, 0.12);
    transform: translateY(-2px);
  }

  .hero__letter:hover {
    color: #f4dfb6;
    filter: drop-shadow(0 0 16px rgba(212, 168, 83, 0.62));
    text-shadow:
      0 0 14px rgba(212, 168, 83, 0.62),
      0 0 40px rgba(212, 168, 83, 0.28),
      0 0 90px rgba(212, 168, 83, 0.16);
    transform: translateY(-4px) scale(1.015);
    transition-delay: 0ms;
  }

  .hero__role {
    align-items: center;
    border: 1px solid var(--border-default);
    border-radius: 999px;
    color: var(--text-primary);
    display: flex;
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    gap: 0.75rem;
    padding: 0.65rem 0.9rem;
    width: fit-content;
  }

  .hero__role span + span {
    color: var(--text-secondary);
  }

  .hero__actions,
  .hero__social {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .hero__social :global(.hero__social-link) {
    align-items: center;
    background: rgba(10, 10, 10, 0.28);
    border: 1px solid var(--border-subtle);
    border-radius: 999px;
    color: var(--text-secondary);
    display: inline-flex;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    gap: 0.4rem;
    min-height: 2.25rem;
    padding: 0 0.75rem;
    transition: background-color 180ms ease, border-color 180ms ease, box-shadow 180ms ease, color 180ms ease, transform 180ms ease;
  }

  .hero__social :global(.hero__social-link:hover),
  .hero__social :global(.hero__social-link:focus-visible) {
    background: rgba(212, 168, 83, 0.11);
    border-color: rgba(212, 168, 83, 0.62);
    box-shadow:
      0 0 0 1px rgba(212, 168, 83, 0.09),
      0 0 18px rgba(212, 168, 83, 0.28),
      0 0 46px rgba(212, 168, 83, 0.13),
      inset 0 0 16px rgba(212, 168, 83, 0.08);
    color: var(--text-accent);
    outline: none;
    transform: translateY(-1px);
  }

  .hero__social :global(.hero__social-link:hover svg),
  .hero__social :global(.hero__social-link:focus-visible svg) {
    filter: drop-shadow(0 0 8px rgba(212, 168, 83, 0.45));
  }

  .hero__tag {
    color: var(--text-muted);
    font-size: 0.78rem;
    margin: 0.5rem 0 0;
  }

  .hero__scroll {
    align-items: center;
    bottom: 2rem;
    color: var(--text-muted);
    display: inline-flex;
    font-size: 0.72rem;
    gap: 0.4rem;
    left: max(1rem, calc((100vw - 1120px) / 2));
    position: absolute;
  }

  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
      padding-top: 8rem;
    }

    .hero__time {
      left: auto;
      position: static;
      top: auto;
    }

    .hero__name {
      font-size: 5rem;
    }
  }

  @media (max-width: 560px) {
    .hero {
      min-height: auto;
      padding-bottom: 6rem;
    }

    .hero__name {
      font-size: 3.5rem;
    }

    .hero__role {
      border-radius: 8px;
      width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__letter {
      transition-delay: 0ms;
    }

    .hero__name:hover .hero__letter,
    .hero__name:focus-visible .hero__letter,
    .hero__letter:hover {
      transform: none;
    }
  }
</style>
