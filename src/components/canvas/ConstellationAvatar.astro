---
// Self-contained canvas avatar. No props, no external render libraries.
---

<div class="avatar-container" role="img" aria-label="Interactive 3D avatar - drag to rotate">
  <canvas id="constellation-face" aria-hidden="true"></canvas>
</div>

<style>
  .avatar-container {
    height: min(55rem, 64vh);
    min-height: 24rem;
    position: relative;
    width: min(100%, 34rem);
  }

  #constellation-face {
    cursor: grab;
    display: block;
    height: 100%;
    touch-action: pan-y;
    width: 100%;
  }

  #constellation-face:active {
    cursor: grabbing;
  }

  @media (max-width: 900px) {
    .avatar-container {
      height: 27rem;
      margin-top: 1rem;
      min-height: 0;
      width: min(calc(100vw - 2rem), 24rem);
    }
  }
</style>

<script>
  interface Vec3 {
    x: number;
    y: number;
    z: number;
  }

  interface ProjectedVertex {
    raw: Vec3;
    rotated: Vec3;
    x: number;
    y: number;
    scale: number;
    visible: boolean;
  }

  interface RenderTriangle {
    tri: [number, number, number];
    normal: Vec3;
    avgZ: number;
    diffuse: number;
  }

  interface Particle {
    x: number;
    y: number;
    z: number;
    vx: number;
    vy: number;
    vz: number;
    radius: number;
  }

  const RAW_VERTS: [number, number, number][] = [
    [0, -280, 20],
    [-80, -260, 30], [80, -260, 30],
    [-150, -220, 10], [150, -220, 10],
    [-170, -160, -20], [170, -160, -20],
    [-100, -200, 60], [100, -200, 60],
    [-50, -210, 70], [50, -210, 70],
    [0, -195, 80],
    [-130, -145, 55], [-60, -140, 80], [60, -140, 80], [130, -145, 55],
    [0, -135, 85],
    [-120, -110, 60], [-75, -105, 90], [-40, -108, 85],
    [120, -110, 60], [75, -105, 90], [40, -108, 85],
    [0, -100, 80],
    [-160, -80, 30], [-100, -70, 85], [100, -70, 85], [160, -80, 30],
    [-140, -50, 20], [140, -50, 20],
    [0, -60, 100], [-30, -30, 95], [30, -30, 95],
    [0, -10, 110], [-35, 5, 80], [35, 5, 80],
    [-20, 15, 90], [20, 15, 90],
    [-60, 40, 75], [60, 40, 75],
    [-35, 55, 85], [35, 55, 85],
    [0, 50, 90], [0, 70, 80],
    [-50, 80, 70], [50, 80, 70],
    [-150, 60, 20], [150, 60, 20],
    [-130, 100, 5], [130, 100, 5],
    [-100, 140, -10], [100, 140, -10],
    [-60, 180, -20], [60, 180, -20],
    [0, 190, -15],
    [-180, -120, -30], [-185, -80, -35], [-178, -50, -25],
    [180, -120, -30], [185, -80, -35], [178, -50, -25],
    [-50, 230, -30], [50, 230, -30],
    [-40, 260, -40], [40, 260, -40],
    [-200, -300, -50], [200, -300, -50],
    [-220, 0, -60], [220, 0, -60],
    [0, 320, -60],
    [-140, 300, -40], [140, 300, -40]
  ];

  const TRIS: [number, number, number][] = [
    [0, 1, 9], [0, 2, 10], [0, 1, 3], [0, 2, 4], [1, 3, 7], [2, 4, 8],
    [7, 8, 11], [7, 9, 11], [8, 10, 11], [9, 10, 11],
    [7, 12, 13], [8, 15, 14], [11, 13, 16], [11, 14, 16],
    [3, 6, 12], [4, 6, 15], [3, 5, 7], [4, 5, 8],
    [12, 13, 17], [15, 14, 20], [13, 16, 18], [14, 16, 21],
    [16, 22, 17], [16, 22, 20],
    [17, 18, 24], [20, 21, 26], [18, 19, 24], [21, 19, 26],
    [13, 18, 17], [14, 21, 20],
    [24, 27, 29], [26, 28, 30], [17, 24, 29], [20, 26, 30],
    [29, 12, 17], [30, 15, 20],
    [22, 23, 31], [22, 25, 32], [23, 25, 31],
    [31, 33, 34], [32, 33, 35], [33, 34, 36], [33, 35, 37],
    [34, 36, 40], [35, 37, 41], [36, 37, 42],
    [36, 40, 43], [37, 41, 44], [43, 44, 45],
    [40, 43, 45], [41, 44, 45], [40, 41, 42], [42, 43, 44],
    [43, 44, 46], [43, 46, 47], [44, 46, 47],
    [29, 48, 50], [30, 49, 51], [50, 52, 54], [51, 53, 55],
    [52, 54, 56], [53, 55, 57], [54, 56, 58], [55, 57, 58],
    [59, 60, 61], [62, 63, 64], [12, 59, 29], [15, 62, 30],
    [56, 58, 65], [57, 58, 66], [65, 66, 67], [65, 67, 68], [66, 67, 69],
    [0, 70, 1], [0, 71, 2], [5, 72, 48], [6, 73, 49],
    [58, 74, 65], [58, 74, 66], [65, 75, 68], [66, 76, 69]
  ];

  const SCALE_FACTOR = 0.85;
  const FOV = 900;
  const DEFAULT_ZOOM = 1.0;
  const MAX_EDGE_DISTANCE = 90;
  const LIGHT = normalize({ x: -0.4, y: -0.7, z: 0.6 });
  const FLOATING_NODE_START = 65;
  const BASE_VERTS = RAW_VERTS.map(([x, y, z]) => ({ x: x * SCALE_FACTOR, y: y * SCALE_FACTOR, z: z * SCALE_FACTOR }));
  const CORRECTED_LOWER_FACE_TRIS: [number, number, number][] = [
    [28, 46, 48], [29, 47, 49],
    [28, 48, 50], [29, 49, 51],
    [38, 46, 50], [39, 47, 51],
    [44, 50, 52], [45, 51, 53],
    [50, 52, 54], [51, 53, 54],
    [52, 54, 61], [53, 54, 62],
    [61, 62, 63], [62, 63, 64],
    [55, 56, 57], [58, 59, 60],
    [12, 55, 28], [15, 58, 29]
  ];
  const FEATURE_EDGES: Array<[number, number]> = [
    [13, 18], [18, 19], [14, 21], [21, 22],
    [16, 30], [30, 31], [30, 32], [31, 33], [32, 33],
    [34, 36], [35, 37], [36, 37],
    [38, 40], [40, 42], [42, 41], [41, 39], [40, 43], [41, 43],
    [24, 28], [27, 29], [46, 48], [47, 49], [52, 54], [53, 54]
  ];
  const MESH_TRIS = [
    ...TRIS.filter((tri) => tri.every((index) => index < 55)),
    ...CORRECTED_LOWER_FACE_TRIS
  ];
  const VALID_TRIS = MESH_TRIS.filter((tri) => tri.every((index) => index >= 0 && index < BASE_VERTS.length));
  const CONSTELLATION_EDGES = precomputeEdges();

  function clamp(value: number, min: number, max: number): number {
    return Math.min(max, Math.max(min, value));
  }

  function normalize(v: Vec3): Vec3 {
    const length = Math.hypot(v.x, v.y, v.z) || 1;
    return { x: v.x / length, y: v.y / length, z: v.z / length };
  }

  function subtract(a: Vec3, b: Vec3): Vec3 {
    return { x: a.x - b.x, y: a.y - b.y, z: a.z - b.z };
  }

  function cross(a: Vec3, b: Vec3): Vec3 {
    return {
      x: a.y * b.z - a.z * b.y,
      y: a.z * b.x - a.x * b.z,
      z: a.x * b.y - a.y * b.x
    };
  }

  function dot(a: Vec3, b: Vec3): number {
    return a.x * b.x + a.y * b.y + a.z * b.z;
  }

  function rotateX(v: Vec3, a: number): Vec3 {
    const c = Math.cos(a);
    const s = Math.sin(a);
    return { x: v.x, y: v.y * c - v.z * s, z: v.y * s + v.z * c };
  }

  function rotateY(v: Vec3, a: number): Vec3 {
    const c = Math.cos(a);
    const s = Math.sin(a);
    return { x: v.x * c + v.z * s, y: v.y, z: -v.x * s + v.z * c };
  }

  function project(v: Vec3, fov: number, cx: number, cy: number): { x: number; y: number; scale: number } {
    const z = v.z + fov;
    const scale = fov / Math.max(z, 1);
    return { x: cx + v.x * scale, y: cy + v.y * scale, scale };
  }

  function precomputeEdges(): Array<[number, number, number]> {
    const edges: Array<[number, number, number]> = [];
    for (let i = 0; i < BASE_VERTS.length; i += 1) {
      for (let j = i + 1; j < BASE_VERTS.length; j += 1) {
        const a = BASE_VERTS[i];
        const b = BASE_VERTS[j];
        const dist = Math.hypot(a.x - b.x, a.y - b.y, a.z - b.z);
        if (dist < MAX_EDGE_DISTANCE) {
          edges.push([i, j, dist]);
        }
      }
    }
    return edges;
  }

  function bootConstellationFace(): void {
    const canvas = document.getElementById("constellation-face");
    if (!(canvas instanceof HTMLCanvasElement) || canvas.dataset.booted === "true") {
      return;
    }

    const ctx = canvas.getContext("2d", { alpha: true });
    const host = canvas.closest<HTMLElement>(".avatar-container");
    if (!ctx || !host) {
      return;
    }

    const faceCanvas = canvas;
    const renderCtx = ctx;
    const avatarHost = host;
    canvas.dataset.booted = "true";
    const state = {
      cx: 0,
      cy: 0,
      dpr: 1,
      dragging: false,
      height: 1,
      idleTimer: 121,
      lastMX: 0,
      lastMY: 0,
      lastTX: 0,
      lastTY: 0,
      mobile: false,
      mouseX: -9999,
      mouseY: -9999,
      rafId: 0,
      rotX: 0,
      rotY: 0.04,
      targetRotX: 0,
      targetRotY: 0.04,
      touchMode: "idle" as "idle" | "rotate" | "scroll",
      width: 1,
      zoom: DEFAULT_ZOOM
    };
    const particles = createParticles(window.innerWidth < 768 ? 25 : 55);
    const projected: ProjectedVertex[] = [];

    function createParticles(count: number): Particle[] {
      return Array.from({ length: count }, () => ({
        x: (Math.random() - 0.5) * 700,
        y: (Math.random() - 0.5) * 760,
        z: (Math.random() - 0.5) * 260,
        vx: (Math.random() - 0.5) * 0.34,
        vy: (Math.random() - 0.5) * 0.28,
        vz: (Math.random() - 0.5) * 0.16,
        radius: 0.8 + Math.random() * 1.4
      }));
    }

    function resize(): void {
      const rect = avatarHost.getBoundingClientRect();
      state.dpr = Math.min(window.devicePixelRatio || 1, 2);
      state.width = Math.max(1, rect.width);
      state.height = Math.max(1, rect.height);
      state.cx = state.width / 2;
      state.cy = state.height / 2;
      state.mobile = window.innerWidth < 768;
      faceCanvas.width = Math.floor(state.width * state.dpr);
      faceCanvas.height = Math.floor(state.height * state.dpr);
      faceCanvas.style.width = `${state.width}px`;
      faceCanvas.style.height = `${state.height}px`;
      renderCtx.setTransform(state.dpr, 0, 0, state.dpr, 0, 0);
    }

    function transformVertex(vertex: Vec3): ProjectedVertex {
      let rotated = rotateX(vertex, state.rotX);
      rotated = rotateY(rotated, state.rotY);
      rotated = { x: rotated.x * state.zoom, y: rotated.y * state.zoom, z: rotated.z * state.zoom };
      const p = project(rotated, FOV, state.cx, state.cy);
      return {
        raw: vertex,
        rotated,
        x: p.x,
        y: p.y,
        scale: p.scale,
        visible: rotated.z > -200
      };
    }

    function updateParticles(): void {
      for (const particle of particles) {
        particle.x += particle.vx;
        particle.y += particle.vy;
        particle.z += particle.vz;
        if (particle.x < -400 || particle.x > 400) particle.vx *= -1;
        if (particle.y < -430 || particle.y > 430) particle.vy *= -1;
        if (particle.z < -150 || particle.z > 150) particle.vz *= -1;
      }
    }

    function drawTriangle(poly: RenderTriangle): void {
      const [ia, ib, ic] = poly.tri;
      const a = projected[ia];
      const b = projected[ib];
      const c = projected[ic];
      const depthFog = clamp((poly.avgZ + 400) / 600, 0, 1);
      const brightness = 0.08 + poly.diffuse * 0.38;
      const r = Math.round(brightness * 210 * depthFog);
      const g = Math.round(brightness * 155 * depthFog);
      const bl = Math.round(brightness * 60 * depthFog);
      const strokeR = Math.round(180 + poly.diffuse * 32);
      const strokeG = Math.round(130 + poly.diffuse * 22);
      const strokeB = Math.round(40 + poly.diffuse * 10);
      const strokeA = 0.35 + poly.diffuse * 0.3;

      renderCtx.beginPath();
      renderCtx.moveTo(a.x, a.y);
      renderCtx.lineTo(b.x, b.y);
      renderCtx.lineTo(c.x, c.y);
      renderCtx.closePath();
      renderCtx.fillStyle = `rgb(${r}, ${g}, ${bl})`;
      renderCtx.fill();
      renderCtx.lineWidth = 0.6;
      renderCtx.strokeStyle = `rgba(${strokeR}, ${strokeG}, ${strokeB}, ${strokeA})`;
      renderCtx.stroke();
    }

    function drawConstellationEdges(): void {
      for (const [aIndex, bIndex, dist] of CONSTELLATION_EDGES) {
        const a = projected[aIndex];
        const b = projected[bIndex];
        if (!a?.visible || !b?.visible) continue;
        const alpha = (1 - dist / MAX_EDGE_DISTANCE) * 0.25;
        renderCtx.beginPath();
        renderCtx.moveTo(a.x, a.y);
        renderCtx.lineTo(b.x, b.y);
        renderCtx.lineWidth = 0.4;
        renderCtx.strokeStyle = `rgba(212, 168, 83, ${alpha})`;
        renderCtx.stroke();
      }
    }

    function drawNodes(): void {
      for (let index = 0; index < projected.length; index += 1) {
        const vertex = projected[index];
        if (!vertex.visible) continue;
        const depthFactor = clamp((vertex.rotated.z + 320) / 520, 0.25, 1);
        const hoverDist = Math.hypot(vertex.x - state.mouseX, vertex.y - state.mouseY);
        const floating = index >= FLOATING_NODE_START;
        const hovered = hoverDist < 80;
        const radius = hovered ? 3 : floating ? 1.8 : 1.2;
        const alpha = hovered ? 1 : (floating ? 0.85 : 0.6) * depthFactor;
        renderCtx.beginPath();
        renderCtx.arc(vertex.x, vertex.y, radius, 0, Math.PI * 2);
        renderCtx.fillStyle = `rgba(212, 168, 83, ${alpha})`;
        renderCtx.fill();
      }
    }

    function drawParticles(): void {
      const transformedParticles = particles.map((particle) => {
        let rotated = rotateX(particle, state.rotX);
        rotated = rotateY(rotated, state.rotY);
        rotated = { x: rotated.x * state.zoom, y: rotated.y * state.zoom, z: rotated.z * state.zoom };
        const p = project(rotated, FOV, state.cx, state.cy);
        return { ...particle, rotated, x2d: p.x, y2d: p.y };
      });

      for (const particle of transformedParticles) {
        const depth = clamp((particle.rotated.z + 260) / 520, 0.15, 1);
        renderCtx.beginPath();
        renderCtx.arc(particle.x2d, particle.y2d, particle.radius, 0, Math.PI * 2);
        renderCtx.fillStyle = `rgba(200, 170, 100, ${0.4 * depth})`;
        renderCtx.fill();

        if (state.mobile) continue;
        let nearest: ProjectedVertex | undefined;
        let nearestDist = 90;
        for (const vertex of projected.slice(0, FLOATING_NODE_START)) {
          const dist = Math.hypot(vertex.x - particle.x2d, vertex.y - particle.y2d);
          if (dist < nearestDist) {
            nearest = vertex;
            nearestDist = dist;
          }
        }
        if (nearest) {
          const alpha = (1 - nearestDist / 90) * 0.18;
          renderCtx.beginPath();
          renderCtx.moveTo(particle.x2d, particle.y2d);
          renderCtx.lineTo(nearest.x, nearest.y);
          renderCtx.lineWidth = 0.35;
          renderCtx.strokeStyle = `rgba(212, 168, 83, ${alpha})`;
          renderCtx.stroke();
        }
      }
    }

    function drawFeatureEdges(): void {
      renderCtx.save();
      renderCtx.globalCompositeOperation = "lighter";
      for (const [aIndex, bIndex] of FEATURE_EDGES) {
        const a = projected[aIndex];
        const b = projected[bIndex];
        if (!a?.visible || !b?.visible) continue;
        const depth = clamp(((a.rotated.z + b.rotated.z) / 2 + 300) / 520, 0.3, 1);
        renderCtx.beginPath();
        renderCtx.moveTo(a.x, a.y);
        renderCtx.lineTo(b.x, b.y);
        renderCtx.lineWidth = 0.75;
        renderCtx.strokeStyle = `rgba(212, 168, 83, ${0.22 + depth * 0.34})`;
        renderCtx.stroke();
      }
      renderCtx.restore();
    }

    function drawFacialCutouts(): void {
      const cutouts: number[][] = [
        [17, 18, 19, 23],
        [20, 21, 22, 23],
        [38, 40, 42, 41, 39, 43]
      ];

      renderCtx.save();
      for (const points of cutouts) {
        const vertices = points.map((index) => projected[index]).filter(Boolean);
        if (vertices.length < 3 || vertices.some((vertex) => !vertex.visible)) continue;
        renderCtx.beginPath();
        renderCtx.moveTo(vertices[0].x, vertices[0].y);
        for (let i = 1; i < vertices.length; i += 1) {
          renderCtx.lineTo(vertices[i].x, vertices[i].y);
        }
        renderCtx.closePath();
        renderCtx.fillStyle = "rgba(5, 5, 4, 0.72)";
        renderCtx.fill();
        renderCtx.lineWidth = 0.65;
        renderCtx.strokeStyle = "rgba(212, 168, 83, 0.42)";
        renderCtx.stroke();
      }
      renderCtx.restore();
    }

    function render(): void {
      state.rafId = window.requestAnimationFrame(render);
      state.idleTimer += 1;
      if (state.idleTimer > 120) {
        state.targetRotY += 0.003;
      }

      state.rotX += (state.targetRotX - state.rotX) * 0.08;
      state.rotY += (state.targetRotY - state.rotY) * 0.08;
      updateParticles();

      renderCtx.clearRect(0, 0, state.width, state.height);
      projected.length = 0;
      for (const vertex of BASE_VERTS) {
        projected.push(transformVertex(vertex));
      }

      const triangles: RenderTriangle[] = [];
      for (const tri of VALID_TRIS) {
        const a = projected[tri[0]].rotated;
        const b = projected[tri[1]].rotated;
        const c = projected[tri[2]].rotated;
        const rawNormal = normalize(cross(subtract(b, a), subtract(c, a)));
        if (Math.abs(rawNormal.z) < 0.02) continue;
        const normal = rawNormal.z < 0
          ? { x: -rawNormal.x, y: -rawNormal.y, z: -rawNormal.z }
          : rawNormal;
        const avgZ = (a.z + b.z + c.z) / 3;
        if (avgZ < -350) continue;
        triangles.push({
          tri,
          normal,
          avgZ,
          diffuse: Math.max(0, dot(normal, LIGHT))
        });
      }

      triangles.sort((a, b) => b.avgZ - a.avgZ);
      drawParticles();
      for (const triangle of triangles) {
        drawTriangle(triangle);
      }
      drawFacialCutouts();
      drawConstellationEdges();
      drawFeatureEdges();
      drawNodes();
    }

    function pointerPosition(event: MouseEvent | Touch): void {
      const rect = faceCanvas.getBoundingClientRect();
      state.mouseX = event.clientX - rect.left;
      state.mouseY = event.clientY - rect.top;
    }

    faceCanvas.addEventListener("mousedown", (event) => {
      state.dragging = true;
      state.lastMX = event.clientX;
      state.lastMY = event.clientY;
      state.idleTimer = 0;
      pointerPosition(event);
    });

    window.addEventListener("mousemove", (event) => {
      pointerPosition(event);
      if (!state.dragging) return;
      state.targetRotY += (event.clientX - state.lastMX) * 0.008;
      state.targetRotX += (event.clientY - state.lastMY) * 0.006;
      state.targetRotX = clamp(state.targetRotX, -0.8, 0.8);
      state.lastMX = event.clientX;
      state.lastMY = event.clientY;
      state.idleTimer = 0;
    });

    window.addEventListener("mouseup", () => {
      state.dragging = false;
    });

    faceCanvas.addEventListener("wheel", (event) => {
      if (!(event.ctrlKey || event.metaKey || event.altKey)) {
        return;
      }

      event.preventDefault();
      const wheelUnit = event.deltaMode === WheelEvent.DOM_DELTA_LINE ? 16 : 1;
      state.zoom = clamp(state.zoom - event.deltaY * wheelUnit * 0.001, 0.62, 1.85);
      state.idleTimer = 0;
    }, { passive: false });

    faceCanvas.addEventListener("touchstart", (event) => {
      const touch = event.touches[0];
      if (!touch) return;
      state.lastTX = touch.clientX;
      state.lastTY = touch.clientY;
      state.touchMode = "idle";
      pointerPosition(touch);
      state.idleTimer = 0;
    }, { passive: true });

    faceCanvas.addEventListener("touchmove", (event) => {
      const touch = event.touches[0];
      if (!touch) return;
      const dx = touch.clientX - state.lastTX;
      const dy = touch.clientY - state.lastTY;
      if (state.touchMode === "idle" && Math.hypot(dx, dy) > 7) {
        state.touchMode = Math.abs(dx) >= Math.abs(dy) * 0.8 ? "rotate" : "scroll";
      }
      if (state.touchMode === "scroll") {
        return;
      }

      event.preventDefault();
      pointerPosition(touch);
      state.targetRotY += dx * 0.01;
      state.targetRotX = clamp(state.targetRotX + dy * 0.008, -0.8, 0.8);
      state.lastTX = touch.clientX;
      state.lastTY = touch.clientY;
      state.idleTimer = 0;
    }, { passive: false });

    faceCanvas.addEventListener("touchend", () => {
      state.touchMode = "idle";
    }, { passive: true });

    faceCanvas.addEventListener("dblclick", () => {
      state.targetRotX = 0;
      state.targetRotY = 0.04;
      state.zoom = DEFAULT_ZOOM;
      state.idleTimer = 0;
    });

    const resizeObserver = new ResizeObserver(resize);
    resizeObserver.observe(avatarHost);
    document.addEventListener("visibilitychange", () => {
      if (document.hidden) {
        window.cancelAnimationFrame(state.rafId);
        return;
      }
      state.rafId = window.requestAnimationFrame(render);
    });

    resize();
    render();
  }

  document.addEventListener("astro:page-load", bootConstellationFace);
  bootConstellationFace();
</script>
