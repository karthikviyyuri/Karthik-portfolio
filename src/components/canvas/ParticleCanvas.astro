<canvas id="particle-canvas" class="particle-canvas" aria-hidden="true" transition:persist></canvas>

<script>
  import { ParticleEngine } from "./useParticleEngine";

  let engine: ParticleEngine | undefined;

  function bootParticleCanvas(): void {
    const canvas = document.getElementById("particle-canvas");
    if (!(canvas instanceof HTMLCanvasElement)) {
      return;
    }

    if (engine) {
      engine.attach(canvas);
    } else {
      engine = new ParticleEngine(canvas);
    }
    engine.start();
  }

  document.addEventListener("astro:page-load", bootParticleCanvas);
  bootParticleCanvas();
</script>

<style>
  .particle-canvas {
    inset: 0;
    pointer-events: none;
    position: fixed;
    width: 100%;
    height: 100%;
    will-change: transform;
    z-index: 0;
  }
</style>

